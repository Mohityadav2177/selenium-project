import telnetlib
import paramiko
import time
import sys
if len(sys.argv) != 4:
ip       = sys.argv[1]
username = sys.argv[2]
password = sys.argv[3]
print(f"\nConnecting to {ip} via Telnet\n")
try:
except Exception as e:
# -------------------------------------------------------
# Core read function — waits until the switch prompt appears
# Prompt can be  #  or  (config)#  etc.
# -------------------------------------------------------
def read_until_prompt(timeout=15):
# -------------------------------------------------------
# Login sequence — wait for explicit prompts
# -------------------------------------------------------
raw = tn.read_until(b"Username:", timeout=10)
tn.write(username.encode("ascii") + b"\n")
raw = tn.read_until(b"Password:", timeout=10)
tn.write(password.encode("ascii") + b"\n")
# Wait for the post-login prompt (#)
login_output = read_until_prompt(timeout=10)
if login_output.strip():
# -------------------------------------------------------
# Step runner
# -------------------------------------------------------
step      = 1
fail_step = None
def run_step(cmd, description, timeout=15):
# -------------------------------------------------------
# SSH login test — separate SSH session, Telnet stays alive
# -------------------------------------------------------
def test_ssh(user, pwd, expect_success=True):
# -------------------------------------------------------
# TEST EXECUTION
# -------------------------------------------------------
print("=================================")
print("STEP 1: Telnet Login")
print("=================================")
print(f"  Host     : {ip}")
print(f"  Username : {username}")
print("✅ STEP 1 PASSED")
if not run_step("configure terminal",                                             "Enter configuration mode"): sys.exit(1)
if not run_step("ip ssh",                                                         "Enable SSH service"):       sys.exit(1)
if not run_step("username hfcl privilege 15 password unencrypted Discover@1234", "Create user hfcl"):         sys.exit(1)
if not run_step("end",                                                            "Exit configuration mode"):  sys.exit(1)
if not run_step("show ip ssh",                                                    "Verify SSH is enabled"):    sys.exit(1)
# SSH should SUCCEED — SSH is enabled
if not test_ssh("hfcl", "Discover@1234", expect_success=True): sys.exit(1)
if not run_step("configure terminal", "Enter config mode again"): sys.exit(1)
if not run_step("no ip ssh",          "Disable SSH"):             sys.exit(1)
if not run_step("end",                "Exit configuration"):      sys.exit(1)
# Telnet verifies SSH disabled — stays connected even when SSH is off
if not run_step("show ip ssh", "Verify SSH is disabled (via Telnet)"): sys.exit(1)
# SSH should FAIL — SSH is now disabled
if not test_ssh("hfcl", "Discover@1234", expect_success=False): sys.exit(1)
if not run_step("show users", "Display logged-in users"): sys.exit(1)
# Restore SSH so the switch stays functional after the test
run_step("configure terminal", "Restore: enter config mode")
run_step("ip ssh",             "Restore: re-enable SSH")
run_step("end",                "Restore: exit config mode")
tn.write(b"exit\n")
tn.close() print("\n=================================")
print("TEST RESULT : PASS")
print("All steps executed successfully")
print("=================================")
